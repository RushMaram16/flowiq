# SmartTrip AI — API Keys Configuration
# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── OpenRouteService (Routing) ───────────────────────────
# Free tier: 500 requests/day, supports driving + walking
# Sign up at: https://openrouteservice.org/sign-up/
ORS_API_KEY=your_ors_key_here

# ── TomTom (Live Traffic) ────────────────────────────────
# Free tier: 2500 requests/day, real-time flow data
# Sign up at: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_key_here

# ── OpenTripMap (POI Dataset Builder) ────────────────────
# Free tier: for build_dataset.py only (one-time run)
# Sign up at: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=your_opentripmap_key_here

# ── Open-Meteo (Weather) ─────────────────────────────────
# Completely FREE — no API key required
# https://open-meteo.com

# ── Optional: Google Maps ────────────────────────────────
# If you want to upgrade routing to Google Routes API
# GOOGLE_MAPS_API_KEY=your_google_key_here

# ── Flask Config ─────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
